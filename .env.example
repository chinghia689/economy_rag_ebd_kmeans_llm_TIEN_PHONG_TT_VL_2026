# ============================================================
# CAU HINH HE THONG (FastAPI)
# ============================================================
ENV=development
# Cac gia tri: development (DEBUG log) hoac production (INFO log)

# ============================================================
# CAU HINH AI ENGINE
# ============================================================
# LLM Provider mac dinh khi khoi dong server
DEFAULT_LLM=openai

# OpenAI
KEY_API_OPENAI=
OPENAI_LLM_MODEL_NAME=gpt-4o-mini

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_LLM_MODEL_NAME=gemini-2.5-flash

# Groq
GROQ_API_KEY=

# ============================================================
# GOOGLE OAUTH 2.0 (Dang nhap)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# JWT Secret Key
# ============================================================
JWT_SECRET_KEY=thay-doi-key-nay-khi-deploy-production

# ============================================================
# OAuth Redirect URI (thay doi theo domain deploy)
# ============================================================
OAUTH_REDIRECT_URI=http://localhost:8001/api/v1/auth/google/callback/flutter
