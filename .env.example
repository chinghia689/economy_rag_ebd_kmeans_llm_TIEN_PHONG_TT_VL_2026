# ============================================================
# CẤU HÌNH HỆ THỐNG (FastAPI)
# ============================================================
ENV=development
# Các giá trị: development (DEBUG log) hoặc production (INFO log)

# Tin tưởng header x-forwarded-for từ reverse proxy (nginx/caddy). Mặc định: false
TRUST_PROXY=false

# ============================================================
# CẤU HÌNH AI ENGINE
# ============================================================
# LLM Provider mặc định khi khởi động server
DEFAULT_LLM=openai

# OpenAI
KEY_API_OPENAI=
OPENAI_LLM_MODEL_NAME=gpt-4o-mini

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_LLM_MODEL_NAME=gemini-2.5-flash

# Groq
GROQ_API_KEY=
GROQ_LLM_MODEL_NAME=llama-3.1-8b-instant

# ============================================================
# GOOGLE OAUTH 2.0 (Đăng nhập)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# JWT Secret Key
# ============================================================
# Bắt buộc đặt giá trị ngẫu nhiên tối thiểu 32 ký tự khi ENV=production.
JWT_SECRET_KEY=

# ============================================================
# OAuth Redirect URI (thay đổi theo domain deploy)
# ============================================================
OAUTH_REDIRECT_URI=http://localhost:8001/api/v1/auth/google/callback/flutter

# ============================================================
# THANH TOÁN (SePay + VietQR)
# ============================================================
# SePay: lấy tại my.sepay.vn → Cài đặt → API Key
SEPAY_API_KEY=
# Số tài khoản ngân hàng liên kết với SePay
SEPAY_ACCOUNT_NUMBER=
# Tên hiển thị trong nội dung chuyển khoản (không dấu, không cách)
NAME_WEB=KTChatbot
# Mã ngân hàng VietQR: MB, VCB, TCB, VPB, ACB, ...
BANK_CODE=MB
# Tên hiển thị ngân hàng trên giao diện
BANK_NAME=MB Bank
# Tên chủ tài khoản (IN HOA, không dấu — khớp với ngân hàng)
BANK_ACCOUNT_NAME=NGUYEN VAN A
